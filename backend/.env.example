# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000

# ── Database (Render PostgreSQL) ──────────────────────────────────────────────
# Copy the "External Database URL" from Render dashboard
# Replace "postgresql://" with "postgresql+asyncpg://" for async driver
# Keep a "postgresql+psycopg2://" version for Alembic (sync)
DATABASE_URL=postgresql+asyncpg://user:pass@host.render.com:5432/dbname
DATABASE_URL_SYNC=postgresql+psycopg2://user:pass@host.render.com:5432/dbname

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Pick exactly ONE provider: openai | openrouter | gemini | anthropic
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# OpenRouter  (set LLM_PROVIDER=openrouter to use)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Google Gemini  (set LLM_PROVIDER=gemini to use)
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash

# Anthropic Claude  (set LLM_PROVIDER=anthropic to use)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ── RAG tuning ────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5
FAISS_INDEX_PATH=./faiss_index

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
